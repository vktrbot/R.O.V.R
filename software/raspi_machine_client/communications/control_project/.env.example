# Signaling server (WebRTC/WebSocket lobby)
ROVR_WS_URL=
ROVR_DEVICE_ID=
ROVR_DEVICE_SECRET=

# TURN server (NAT traversal)
ROVR_TURN_URL=
ROVR_TURN_USER=
ROVR_TURN_PASS=
